# Database
DATABASE_URL=postgresql://user:password@localhost:5432/companyhq

# Session secret (generate a long random string)
SESSION_SECRET=your-session-secret-here

# QuickBooks Online Integration
# Get these from https://developer.intuit.com → your app → Keys & credentials
QB_CLIENT_ID=your_intuit_client_id_here
QB_CLIENT_SECRET=your_intuit_client_secret_here

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key_here

# OpenAI (AI features)
OPENAI_API_KEY=sk-your_openai_api_key_here
