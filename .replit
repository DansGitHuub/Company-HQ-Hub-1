modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["imagemagick"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5050
externalPort = 3003

[[ports]]
localPort = 23636
externalPort = 3001



[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
publicDir = "dist/public"
run = ["node", "./dist/index.cjs"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[agent]
mockupState = "FULLSTACK"
integrations = ["javascript_database:1.0.0", "javascript_auth_all_persistance:1.0.0", "javascript_object_storage:2.0.0", "javascript_openai_ai_integrations:2.0.0", "resend:1.0.0", "google-calendar:1.0.0"]

[userenv]

[userenv.production]
ADMIN_SETUP_CODE = "CompanyHQ2026!"

[objectStorage]
defaultBucketID = "replit-objstore-a9e18d46-f663-49f2-a6b5-e31b7d9ddb0e"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
